# Copy to .env and fill in. NEVER commit the real .env.
# DingTalk Stream-mode app credentials (Internal app -> 凭证与基础信息).
HIVEMIND_DINGTALK__CLIENT_ID=dingxxxxxxxxxxxxxxxx
HIVEMIND_DINGTALK__CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override runtime dir (default: <project>/var)
# HIVEMIND_VAR_DIR=/Users/me/hivemind-var

# Optional: local hooks HTTP server port
# HIVEMIND_HOOKS__PORT=8787
